{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "store:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "updater:default"
  ]
}
